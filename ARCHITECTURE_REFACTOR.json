{
  "audit_summary": {
    "total_files_estimated": "150+",
    "core_directory_files": "120+",
    "api_directory_files": "30+",
    "critical_issues": [
      "Massive core/ directory with 120+ files - violates single responsibility",
      "Mixed concerns: planning, execution, evolution, memory, validation all in core/",
      "Duplicate functionality: multiple planners, validators, analyzers",
      "No clear domain boundaries",
      "Infrastructure mixed with domain logic",
      "Application layer partially exists but underutilized",
      "Tool creation/evolution split between core/ and application/",
      "Services scattered across core/services/ and core/tool_services.py"
    ],
    "strengths": [
      "Good separation of skills system",
      "Clean tool interface design",
      "Experimental tools properly isolated",
      "UI properly separated",
      "Domain/ and infrastructure/ directories started but incomplete"
    ]
  },
  
  "proposed_architecture": {
    "description": "Clean Architecture with DDD principles - Hexagonal/Ports & Adapters pattern",
    "layers": {
      "domain": {
        "description": "Pure business logic, no dependencies on infrastructure",
        "subdirectories": {
          "entities": ["Task", "Tool", "Skill", "Gap", "Evolution", "Plan", "Execution"],
          "value_objects": ["ToolCapability", "SkillScore", "HealthStatus", "EvolutionProposal"],
          "repositories": ["IToolRepository", "ISkillRepository", "IGapRepository", "IExecutionRepository"],
          "services": ["ToolEvolutionService", "GapAnalysisService", "SkillRoutingService"],
          "events": ["ToolCreated", "GapDetected", "ExecutionCompleted", "EvolutionProposed"]
        }
      },
      "application": {
        "description": "Use cases and orchestration - no infrastructure details",
        "subdirectories": {
          "use_cases": {
            "chat": ["HandleUserMessage", "ExecuteToolChain", "GenerateResponse"],
            "tool_lifecycle": ["CreateTool", "EvolveTool", "ValidateTool", "ActivateTool"],
            "planning": ["CreateExecutionPlan", "ReplanOnFailure", "OptimizePlan"],
            "evolution": ["AnalyzeGaps", "ProposeEvolution", "ApplyEvolution"],
            "autonomy": ["RunAutonomyCycle", "CheckSystemHealth", "ResolveCapabilities"]
          },
          "dto": ["ToolCreationRequest", "EvolutionRequest", "ExecutionResult"],
          "ports": {
            "inbound": ["IChatHandler", "IToolManager", "IAutonomyController"],
            "outbound": ["ILLMProvider", "IStorageProvider", "IValidationProvider"]
          }
        }
      },
      "infrastructure": {
        "description": "External concerns - databases, LLMs, file system, APIs",
        "subdirectories": {
          "persistence": {
            "sqlite": ["CUADatabase", "ToolRepository", "SkillRepository", "GapRepository"],
            "file_storage": ["ToolFileStorage", "SkillFileStorage", "MemoryStorage"]
          },
          "llm": {
            "providers": ["OllamaProvider", "OpenAIProvider", "AnthropicProvider"],
            "adapters": ["LLMGateway", "PromptBuilder", "ResponseParser"]
          },
          "validation": {
            "ast": ["ASTValidator", "ArchitectureValidator", "SecurityValidator"],
            "sandbox": ["UnifiedSandboxRunner", "IsolationManager"]
          },
          "messaging": ["EventBus", "WebSocketBroadcaster"],
          "external": ["MCPProcessManager", "HTTPClient", "ShellExecutor"]
        }
      },
      "api": {
        "description": "HTTP/WebSocket interface - thin adapter layer",
        "subdirectories": {
          "rest": {
            "chat": ["chat_router", "message_handler"],
            "tools": ["tools_router", "tool_management_router"],
            "evolution": ["evolution_router", "auto_evolution_router"],
            "autonomy": ["autonomy_router", "health_router"],
            "observability": ["observability_router", "metrics_router"]
          },
          "websocket": ["trace_ws", "autonomy_ws"],
          "middleware": ["error_handler", "correlation_context", "auth"],
          "dto": ["request_models", "response_models"]
        }
      }
    }
  },

