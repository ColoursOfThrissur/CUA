{
  "name": "code_workspace",
  "category": "development",
  "description": "Code development, repository analysis, testing, script execution, and development workflow automation.",
  "trigger_examples": [
    "inspect this codebase",
    "fix this bug",
    "implement this feature",
    "refactor this module",
    "run tests and update the code",
    "analyze code quality",
    "review this pull request",
    "run this python script",
    "execute these tests",
    "search for files matching",
    "read this source file",
    "write this code to file",
    "copy this file",
    "move this module",
    "check if this file exists",
    "get file metadata",
    "run git status",
    "run pip install",
    "check which python is installed",
    "create this directory structure",
    "append to this log file"
  ],
  "preferred_tools": [
    "FilesystemTool",
    "ShellTool"
  ],
  "required_tools": [],
  "preferred_connectors": [],
  "input_types": [
    "repo_task",
    "file_path",
    "test_request",
    "code_change_request",
    "script"
  ],
  "output_types": [
    "code_summary",
    "change_summary",
    "diff_result",
    "validation_result",
    "test_result",
    "script_output",
    "file_info"
  ],
  "verification_mode": "validation_and_tests",
  "risk_level": "high",
  "ui_renderer": "code_result",
  "fallback_strategy": "partial_result_with_gap_recording"
}
